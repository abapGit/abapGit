{
  "global": {
    "files": [
      "/src/ui/core/**/*.*",
      "/src/utils/**/*.*",
      "/src/zif_abapgit_definitions.*",
      "/src/git/zif_abapgit_git_definitions.*",
      "/src/objects/aff_types/zif_abapgit_aff_types_v1.*",
      "/src/zcx_abapgit_exception.*"
    ],
    "skipGeneratedFunctionGroups": true,
    "skipGeneratedGatewayClasses": true,
    "skipGeneratedPersistentClasses": true
  },
  "dependencies": [
    {
      "files": "/**/*.*",
      "folder": "/../deps"
    },
    {
      "url": "https://github.com/abaplint/deps",
      "files": "/src/**/*.*",
      "folder": "/../lint_deps"
    }
  ],
  "syntax": {
    "version": "v702",
    "errorNamespace": "^(Z|Y|LT?CL_|TY_|LIF_|C_|.*ABAPGIT)",
    "globalConstants": []
  },
  "rules": {
    "check_syntax": true,
    "parser_error": true,
    "unknown_types": true
  }
}
